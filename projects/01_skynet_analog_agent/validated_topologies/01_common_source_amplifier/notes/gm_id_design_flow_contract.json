    ],
    "capacitance": [
      "cgg",
      "cgs",
      "cgd",
      "cdd"
    ],
    "region": [
      "region",
      "operating_region",
      "region_flag"
    ],
    "sat_margin": [
      "sat_margin",
      "saturation_margin",
      "vds_minus_vov",
      "vsd_minus_vov"
    ],
    "bias": [
      "vgs",
      "VGS",
      "vsg",
      "VSG",
      "vds",
