    ]
  },
  "no_fake_rules": [
    "If required LUT columns are missing, return LUT_SCHEMA_MISSING_FIELD.",
    "If no valid row exists, return LUT_LIMIT_REACHED.",
    "Do not invent gm, gds, gm/Id, ft or region.",
    "Final pass requires real LTspice simulation verification."
  ]
}