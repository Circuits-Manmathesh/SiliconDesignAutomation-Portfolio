{
  "schema_version": "2.0",
  "topology_type": "common_source_amplifier",
  "topology_variant": "common_source_pmos_load",
  "technology_id": "50nm_cmosedu",
  "simulator_backend": "ltspice",
  "contract_status": "PRODUCTION_READY_FOR_PROJECT_LOCAL_FLOW",
  "artifact_identity_required": true,
  "legacy_root_fallback_allowed": false,
  "netlist_family": "ltspice_text_netlist",
  "unit_safe_rendering_required": true,
  "render_contract_status": "PRODUCTION_RENDER_READY",
  "model_library": {
    "path_policy": "use_project_or_root_source_of_truth",
    "default_relative_path_from_root": "technology_models/models.lib",
    "expected_absolute_path": "C:\\Skynet_Setup\\skynet_analog_agent\\technology_models\\models.lib"
  },
  "default_render_values": {
    "VDD": "1.0",
    "VSS": "0",
    "CL": "1p",
    "VIN_CM": "0.50",
    "VBP": "0.45",
    "VIN_AC": "1",
    "VIN_STEP": "10m",
    "TRISE": "20p",
    "TFALL": "20p",
    "TPER": "2n",
    "WN": "1u",
    "LN": "200n",
    "MN": "1",
    "WP": "2u",
    "LP": "400n",
    "MP": "1"
  },
  "device_instance_map": [
    {
      "name": "M_NCS",
      "syntax": "M_NCS VOUT VIN VSS VSS N_50n W={WN} L={LN} m={MN}",
      "device_type": "nmos",
      "model_name": "N_50n",
      "role": "input_transconductance_device"
    },
    {
      "name": "M_PLOAD",
      "syntax": "M_PLOAD VOUT VBP VDD VDD P_50n W={WP} L={LP} m={MP}",
      "device_type": "pmos",
      "model_name": "P_50n",
      "role": "active_load_current_source"
    }
  ],
  "analysis_netlists": {
    "op": [
      "* Project: {PROJECT_ID} | Topology: common_source_amplifier | Analysis: OP",
      ".include \"{MODEL_LIBRARY_PATH}\"",
      ".param VDD={VDD}",
      ".param CL={CL}",
      ".param VIN_CM={VIN_CM}",
      ".param VBP={VBP}",
      "VDD_SRC VDD VSS {VDD}",
      "VIN_SRC VIN VSS {VIN_CM}",
      "VBP_SRC VBP VSS {VBP}",
      "M_NCS VOUT VIN VSS VSS N_50n W={WN} L={LN} m={MN}",
      "M_PLOAD VOUT VBP VDD VDD P_50n W={WP} L={LP} m={MP}",
      "CLOAD VOUT VSS {CL}",
      ".op",
      ".save V(VIN) V(VOUT) V(VDD) V(VBP) I(VDD_SRC)",
      ".end"
    ],
    "dc": [
      "* Project: {PROJECT_ID} | Topology: common_source_amplifier | Analysis: DC",
      ".include \"{MODEL_LIBRARY_PATH}\"",
      ".param VDD={VDD}",
      ".param CL={CL}",
      ".param VBP={VBP}",
      "VDD_SRC VDD VSS {VDD}",
      "VIN_SRC VIN VSS 0",
      "VBP_SRC VBP VSS {VBP}",
      "M_NCS VOUT VIN VSS VSS N_50n W={WN} L={LN} m={MN}",
      "M_PLOAD VOUT VBP VDD VDD P_50n W={WP} L={LP} m={MP}",
      "CLOAD VOUT VSS {CL}",
      ".dc VIN_SRC 0 {VDD} 1m",
      ".save V(VIN) V(VOUT) V(VDD) V(VBP) I(VDD_SRC)",
      ".end"
    ],
    "ac": [
      "* Project: {PROJECT_ID} | Topology: common_source_amplifier | Analysis: AC",
      ".include \"{MODEL_LIBRARY_PATH}\"",
      ".param VDD={VDD}",
      ".param CL={CL}",
      ".param VIN_CM={VIN_CM}",
      ".param VBP={VBP}",
      ".param VIN_AC={VIN_AC}",
      "VDD_SRC VDD VSS {VDD}",
      "VIN_SRC VIN VSS DC {VIN_CM} AC {VIN_AC}",
      "VBP_SRC VBP VSS {VBP}",
      "M_NCS VOUT VIN VSS VSS N_50n W={WN} L={LN} m={MN}",
      "M_PLOAD VOUT VBP VDD VDD P_50n W={WP} L={LP} m={MP}",
      "CLOAD VOUT VSS {CL}",
      ".ac dec 100 1k 10G",
      ".save V(VIN) V(VOUT) V(VDD) V(VBP) I(VDD_SRC)",
      ".end"
    ],
    "tran": [
      "* Project: {PROJECT_ID} | Topology: common_source_amplifier | Analysis: TRAN",
      ".include \"{MODEL_LIBRARY_PATH}\"",
      ".param VDD={VDD}",
      ".param CL={CL}",
      ".param VIN_CM={VIN_CM}",
      ".param VBP={VBP}",
      ".param VIN_STEP={VIN_STEP}",
      ".param TRISE={TRISE}",
      ".param TFALL={TFALL}",
      ".param TPER={TPER}",
      "VDD_SRC VDD VSS {VDD}",
      "VIN_SRC VIN VSS PULSE({VIN_CM}-0.5*{VIN_STEP} {VIN_CM}+0.5*{VIN_STEP} 100p {TRISE} {TFALL} 0.5*{TPER} {TPER})",
      "VBP_SRC VBP VSS {VBP}",
      "M_NCS VOUT VIN VSS VSS N_50n W={WN} L={LN} m={MN}",
      "M_PLOAD VOUT VBP VDD VDD P_50n W={WP} L={LP} m={MP}",
      "CLOAD VOUT VSS {CL}",
      ".tran 0 10n 0 1p",
      ".save V(VIN) V(VOUT) V(VDD) V(VBP) I(VDD_SRC)",
      ".end"
    ]
  }
}