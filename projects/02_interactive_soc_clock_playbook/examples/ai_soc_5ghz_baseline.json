"demo_interpretation": {
"baseline_message": "The baseline represents a stable 5 GHz architecture-level clock-distribution case with positive setup and hold slack.",
"clock_message": "At 5 GHz, the 200 ps period makes picosecond-level edge movement important.",
"rc_message": "The global wire has significant unbuffered RC severity, but repeater segmentation reduces effective segment RC.",
"jitter_message": "Endpoint jitter is built from PLL jitter, RC uncertainty, PSIJ, and crosstalk contributions.",
"skew_message": "Spatial skew and useful skew must be reviewed together because useful skew can improve setup but reduce hold margin.",
"power_message": "Dynamic VDD droop creates PSIJ and shows why EMIR awareness matters for clock timing.",
